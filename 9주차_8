clear; clc;

x = -2*pi : 0.1 : 2*pi;
y = -2*pi : 0.1 : 2*pi;
[X, Y] = meshgrid(x, y);

z = sin(X) .* cos(Y);

figure;

subplot(1, 2, 1);
mesh(X, Y, z);
title('Mesh Plot');
xlabel('x'); ylabel('y'); zlabel('z');
grid on;

subplot(1, 2, 2);
contour(X, Y, z);
title('Contour Plot');
xlabel('x'); ylabel('y');
grid on;
