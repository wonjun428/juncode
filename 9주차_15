clear; clc;

A = [4 -1 2; 1 3 -1; 2 -2 5];
b = [7; 4; 10];

A_sq_matrix = A^2;
A_sq_element = A.^2;

det_A = det(A);

x_inv = inv(A) * b;
x_backslash = A \ b;

x_solution = x_backslash;

fprintf('(a) 행렬 곱 A^2 결과:\n'); disp(A_sq_matrix);
fprintf('(a) 원소별 제곱 A.^2 결과:\n'); disp(A_sq_element);
fprintf('(b) det(A) = %.2f\n', det_A);
fprintf('(c) inv(A)*b 결과:\n'); disp(x_inv);
fprintf('(c) A\\b 결과:\n'); disp(x_backslash);
