x = 0:0.01:2;

u = 3 * log10(70 * x + 1);
v = 4 * cos(7 * x);


plot(x, u, 'r-', 'LineWidth', 2);
hold on;
plot(x, v, 'b--', 'LineWidth', 2);

title('Velocity vs Distance');
xlabel('Distance (mile)');
ylabel('Velocity (mile/hour)');
legend('u = 3log10(70x + 1)', 'v = 4cos(7x)');

grid on;

hold off;
