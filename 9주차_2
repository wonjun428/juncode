clear; clc;

x = 1 : 1 : 50;
y = 3.^x;

figure;

subplot(1, 2, 1);
plot(x, y, 'b-o', 'LineWidth', 1);
title('Linear Scale (plot)');
xlabel('x');
ylabel('y = 3^x');
grid on;

subplot(1, 2, 2);
semilogy(x, y, 'r-s', 'LineWidth', 1);
title('Logarithmic Scale (semilogy)');
xlabel('x');
ylabel('y = 3^x (log scale)');
grid on;
